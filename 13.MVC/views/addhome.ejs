<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Home</title>
  <link href="/output.css" rel="stylesheet">
</head>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <div class="mx-auto max-w-2xl px-4 py-10">
    <header class="mb-6 rounded-2xl bg-white p-6 shadow-sm">
      <h1 class="text-2xl font-semibold">Add your home here</h1>
    </header>
    <main class="rounded-2xl bg-white p-6 shadow-sm">
      <form action="/host/add-home" method="POST" class="space-y-4">
        <input type="text" name="title" placeholder="Enter name of your house" required class="w-full rounded-xl border border-slate-300 px-4 py-3 focus:border-sky-500 focus:outline-none" />
        <button type="submit" class="inline-flex items-center justify-center rounded-full bg-sky-600 px-5 py-3 text-sm font-semibold text-white hover:bg-sky-700">Submit</button>
      </form>
    </main>
  </div>
</body>
</html>
