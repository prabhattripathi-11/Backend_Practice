<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <%- include('../partials/header') %>

    <main class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-3xl font-semibold text-slate-900">Admin Home List</h2>
          <p class="mt-2 text-slate-600">Manage homes and keep the edit/delete actions ready.</p>
        </div>
        <a href="/host/add-home" class="rounded-full bg-sky-600 px-4 py-2 text-sm font-semibold text-white">Add Home</a>
      </div>

      <% if (homes.length > 0) { %>
        <div class="mt-8 space-y-4">
          <% homes.forEach(home => { %>
            <div class="flex flex-col gap-4 rounded-2xl border border-slate-200 p-5 md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="text-lg font-semibold text-slate-900"><%= home.title %></h3>
                <p class="mt-1 text-sm text-slate-600"><%= home.location %> • ₹<%= home.price %> • <%= home.rating %>/5</p>
              </div>
              <div class="flex gap-2">
                <a href="/admin/edit-home" class="rounded-full bg-amber-500 px-4 py-2 text-sm font-semibold text-white">Edit</a>
                <a href="/admin/delete-home" class="rounded-full bg-rose-600 px-4 py-2 text-sm font-semibold text-white">Delete</a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="mt-8 text-sm text-slate-500">No homes available yet.</p>
      <% } %>
    </main>
  </div>
</body>
</html>
