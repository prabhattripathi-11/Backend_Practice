<%-include('partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <div class="mx-auto max-w-5xl px-4 py-10">
    <%-include('partials/header') %>

    <main class="space-y-6 px-2">
      <ul class="space-y-3">
        <% homeRegister.forEach(home =>{ %>
          <li class="rounded-xl bg-slate-100 px-4 py-3 text-slate-900 shadow-sm">
            <%= home.title %>
          </li>
        <% }) %>
      </ul>
      <a href="/host/add-home" class="inline-block rounded-full bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-700">Add Home</a>
    </main>
  </div>
</body>
</html>