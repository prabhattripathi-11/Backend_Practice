<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <%- include('../partials/header') %>

    <main class="space-y-6 px-2">
      <% if (homes.length === 0) { %>
        <div class="rounded-2xl bg-white p-8 shadow-sm text-center">
          <p class="text-lg font-medium text-slate-900">No homes registered yet.</p>
          <p class="mt-2 text-sm text-slate-500">Use the Add Home tab to add a new listing.</p>
        </div>
      <% } else { %>
        <div class="grid gap-6 md:grid-cols-2">
          <% homes.forEach(home => { %>
            <article class="overflow-hidden rounded-3xl bg-white shadow-sm ring-1 ring-slate-200">
              <% if (home.photo) { %>
                <img src="<%= home.photo %>" alt="<%= home.title %>" class="h-52 w-full object-cover" />
              <% } else { %>
                <div class="flex h-52 items-center justify-center bg-slate-100 text-slate-500">No photo provided</div>
              <% } %>
              <div class="p-5">
                <div class="flex items-center justify-between gap-4">
                  <h2 class="text-xl font-semibold text-slate-900"><%= home.title %></h2>
                  <span class="rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-700">₹<%= home.price %> / night</span>
                </div>
                <p class="mt-3 text-sm text-slate-600">Location: <span class="font-medium text-slate-900"><%= home.location %></span></p>
                <p class="mt-2 text-sm text-slate-600">Rating: <span class="font-medium text-slate-900"><%= home.rating %> / 5</span></p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <a href="/store/home-detail" class="rounded-full bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700">View Details</a>
                  <a href="/store/reserve" class="rounded-full bg-sky-600 px-3 py-2 text-sm font-semibold text-white">Reserve</a>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </main>
  </div>
</body>
</html>