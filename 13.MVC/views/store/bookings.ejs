<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <%- include('../partials/header') %>

    <main class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
      <h2 class="text-3xl font-semibold text-slate-900">My Bookings</h2>
      <p class="mt-3 text-slate-600">Booking history will appear here once the flow is completed.</p>
      <% if (homes.length > 0) { %>
        <div class="mt-6 space-y-3">
          <% homes.forEach(home => { %>
            <div class="rounded-2xl border border-slate-200 p-4">
              <h3 class="font-semibold text-slate-900"><%= home.title %></h3>
              <p class="mt-1 text-sm text-slate-600"><%= home.location %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="mt-6 text-sm text-slate-500">No bookings yet.</p>
      <% } %>
    </main>
  </div>
</body>
</html>
