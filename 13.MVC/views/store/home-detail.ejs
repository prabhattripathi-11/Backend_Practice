<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <%- include('../partials/header') %>

    <main class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div>
          <h2 class="text-3xl font-semibold text-slate-900">Home Details</h2>
          <p class="mt-3 text-slate-600">This is a placeholder detail page for the selected listing.</p>
          <% if (home) { %>
            <div class="mt-6 rounded-2xl bg-slate-50 p-6">
              <h3 class="text-xl font-semibold text-slate-900"><%= home.title %></h3>
              <p class="mt-2 text-sm text-slate-600">Location: <span class="font-medium text-slate-900"><%= home.location %></span></p>
              <p class="mt-2 text-sm text-slate-600">Price: <span class="font-medium text-slate-900">₹<%= home.price %></span></p>
              <p class="mt-2 text-sm text-slate-600">Rating: <span class="font-medium text-slate-900"><%= home.rating %> / 5</span></p>
            </div>
          <% } else { %>
            <p class="mt-6 text-sm text-slate-500">No homes are available yet.</p>
          <% } %>
        </div>
        <div class="rounded-2xl bg-sky-50 p-6">
          <h3 class="text-lg font-semibold text-slate-900">Quick actions</h3>
          <div class="mt-4 space-y-3">
            <a href="/store/reserve" class="block rounded-full bg-sky-600 px-4 py-2 text-center text-sm font-semibold text-white">Reserve this home</a>
            <a href="/store/favourite-list" class="block rounded-full border border-sky-600 px-4 py-2 text-center text-sm font-semibold text-sky-700">Save to favourites</a>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
